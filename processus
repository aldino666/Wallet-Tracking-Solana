use solana_sdk::pubkey::Pubkey;
use solana_transaction_status::EncodedConfirmedTransactionWithStatusMeta;
use std::str::FromStr;

pub const RAYDIUM_AMM_V4: &str = "675kPX9MHTjS2zt1qfr1NYHuzeLXfQM9H24wFSUt1Mp8";
pub const ORCA_SWAP_V2: &str = "9W959DqmcGTu2kC9SghpCC2JzxeH9M89S6s5zX6U9L1i";
pub const METEORA_AMM: &str = "Eo7WjKq67rjJQSvSDB9UpXyP3od729fmH799yB5BpqLd";
pub const PHOENIX_V1: &str = "PhoeNiXNJ9bhP7th6vXgAn9N9h7Hym4atpZuhS7Ppt1";

#[derive(Debug, PartialEq)]
pub enum ActionType {
    Buy,
    Sell,
    LiquidityAdd,
    Transfer,
    Unknown,
}

pub struct DecodedAction {
    pub action: ActionType,
    pub token_mint: Option<Pubkey>,
    pub amount: f64,
    pub program_id: Pubkey,
}

pub fn is_dex_program(program_id: &Pubkey) -> bool {
    let id_str = program_id.to_string();
    id_str == RAYDIUM_AMM_V4 || id_str == ORCA_SWAP_V2 || id_str == METEORA_AMM || id_str == PHOENIX_V1
}

pub fn parse_transaction(tx: &EncodedConfirmedTransactionWithStatusMeta, _target_wallet: &Pubkey) -> Vec<DecodedAction> {
    let mut actions = Vec::new();
    let meta = match &tx.transaction.meta {
        Some(m) => m,
        None => return actions,
    };

    if let solana_transaction_status::option_serializer::OptionSerializer::Some(logs) = &meta.log_messages {
        for log in logs {
            if log.contains("Instruction: Swap") || log.contains("Instruction: Route") {
                actions.push(DecodedAction {
                    action: ActionType::Buy,
                    token_mint: None,
                    amount: 0.0,
                    program_id: Pubkey::from_str(RAYDIUM_AMM_V4).unwrap(),
                });
            }
        }
    }

    actions
}
